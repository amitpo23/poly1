# --- Required ---
POLYGON_WALLET_PRIVATE_KEY=""
OPENAI_API_KEY=""

# Polymarket proxy address (the wallet shown on polymarket.com/settings).
# REQUIRED for accounts created via Google/email login (Privy/Magic embedded
# wallet) — the EOA derived from the private key signs orders, but the proxy
# is the order funder and balance holder. Leave blank for classic EOA-only
# (MetaMask) wallets.
POLYMARKET_FUNDER=""

# Deposit-wallet mode (current Polymarket API path for new API users).
# Once deployed/funded, set this and leave POLYMARKET_SIGNATURE_TYPE=3.
POLYMARKET_DEPOSIT_WALLET=""
POLYMARKET_SIGNATURE_TYPE=""

# Required only for automated deposit-wallet deployment/approval/migration via
# scripts/python/setup_deposit_wallet.py.
BUILDER_API_KEY=""
BUILDER_SECRET=""
BUILDER_PASS_PHRASE=""
POLYMARKET_RELAYER_URL="https://relayer-v2.polymarket.com/"

# Optional: persist CLOB L2 credentials after deriving them once. If these are
# blank, the bot derives them from POLYGON_WALLET_PRIVATE_KEY at startup.
POLYMARKET_CLOB_API_KEY=""
POLYMARKET_CLOB_API_SECRET=""
POLYMARKET_CLOB_API_PASSPHRASE=""

# Optional: order attribution for builder integrations. Leave blank unless you
# created a builder code in Polymarket settings.
POLYMARKET_BUILDER_CODE=""
POLYMARKET_BUILDER_ADDRESS=""

# --- Optional but used by features ---
TAVILY_API_KEY=""
NEWSAPI_API_KEY=""

# Tavily is budgeted aggressively. Keep disabled by default; if enabled, the
# helper only spends a few cached/critical searches per day.
TAVILY_ENABLED="false"
TAVILY_DAILY_LIMIT="5"
TAVILY_CACHE_TTL_SEC="21600"
TAVILY_MIN_QUERY_INTERVAL_SEC="900"
TAVILY_MAX_RESULTS="2"
TAVILY_CRITICAL_ONLY="true"

# --- Model ---
# Recommended live default: gpt-4o for smarter brain/exit decisions.
OPENAI_MODEL="gpt-4o"
ANTHROPIC_MODEL="claude-sonnet-4-5-20250929"

# --- Trader runtime ---
# Set EXECUTE=true to leave dry-run and place real orders. Default false.
EXECUTE="false"
# Shadow-only experiments may continue producing paper decisions even when the
# live risk gate blocks entries. Ignored when EXECUTE=true.
SHADOW_IGNORE_RISK_GATE="false"
CYCLE_SECONDS="60"            # one minute between sweeps
CYCLE_JITTER_SECONDS="0"
TOP_N="3"
MAX_TRADES_PER_CYCLE="2"
MAX_POSITION_FRACTION="0.05"
MIN_CONFIDENCE="0.65"  # only enter when LLM is confident — fewer but better trades

# --- Risk gates ---
# Set this to your wallet's actual starting balance so drawdown is measured correctly.
STARTING_BALANCE_USDC="50.0"
MAX_DAILY_LOSS_PCT="0.10"     # halt trading if drawdown exceeds 10%
MAX_TRADES_PER_HOUR="100"      # hard ceiling; brain/risk gates still decide if a trade is allowed
MAX_AGENT_ALLOCATION_FRACTION="0.50"  # any one live agent may receive at most 50% of wallet capital
POLY1_REQUIRE_BRAIN_APPROVAL="true"   # live entries must pass the brain/signal layer
POLY1_SOFT_STOP_LOSS_PCT="0.03"
POLY1_STOP_LOSS_PCT="0.06"
POLY1_PROFIT_TAKE_ALLOWED_PCT="0.015"
POLY1_FAST_TAKE_PROFIT_PCT="0.04"
POLY1_PREFERRED_TAKE_PROFIT_HIGH_PCT="0.08"
POLY1_TAKE_PROFIT_CAP_PCT="0.25"
KELLY_SIZING_ENABLED="true"           # size entries by brain probability vs market price
KELLY_FRACTION_SCALE="0.25"           # use conservative fractional Kelly
KELLY_MIN_POSITION_USDC="0"           # let exitable-size checks decide minimums
MIN_USDC_FLOOR="10.0"
MAX_DAILY_TOKEN_USD="5.0"
KILL_SWITCH_FILE="/app/data/HALT"

# Opportunity Router: set to false until OpportunityRouter.persist_latest_routes() is
# wired into a periodic daemon and scout.db has fresh live_probe routes.
# When true, every live trade requires a matching live_probe route in scout.db.
OPPORTUNITY_ROUTER_ENFORCE_LIVE="false"
# Path to the scout DB written by the opportunity_router daemon (if running).
SCOUT_DB="./data/scout.db"

# Slippage guard: reject FOK market buys where the effective price exceeds the
# model price by more than this fraction. Default 0.03 (3%).
POLYMARKET_MAX_SLIPPAGE="0.03"

# Minimum USDC per live order. Orders smaller than this are skipped. Default 1.0.
POLYMARKET_MIN_ORDER_USDC="1.0"

# Entry quality guards (applied in _fillable_market_buy before FOK submit).
MIN_ENTRY_PRICE="0.10"           # Skip penny tokens below this price
MIN_BID_DEPTH_USDC="20.0"       # Require $20 bid-side depth for exit liquidity
MAX_ENTRY_SPREAD_PCT="0.05"      # Reject bid-ask spread wider than 5%

# Post-close re-entry cooldown: block re-entry on a market for N hours after
# a terminal close (timeout/SL/TP/dust). Prevents buy→close→re-buy spread drain.
REENTRY_COOLDOWN_HOURS="12"

# Per-market concentration limit: max filled entries on one market in 24h.
# After the 6h dedupe expires, agents can re-enter endlessly without this.
MAX_FILLS_PER_MARKET_24H="3"

# Pre-exit bid depth: defer non-stop-loss exits when bid-side depth < this.
# stop_loss always attempts regardless (capital preservation > execution quality).
MIN_EXIT_BID_DEPTH_USDC="5.0"

# Polygon RPC endpoint. Override with a paid Alchemy/Infura/QuickNode URL for
# production stability. Default uses a public free node.
POLYGON_RPC="https://polygon.drpc.org"

# --- Persistence ---
TRADE_LOG_DB="/app/data/trade_log.db"
LLM_USAGE_FILE="/app/data/llm_usage.jsonl"
LOG_DIR="/app/data/logs"
LOG_LEVEL="INFO"
HEARTBEAT_PATH="/app/data/heartbeat"

# --- Notifications ---
TG_BOT_TOKEN=""
TG_CHAT_ID=""
HEALTHCHECK_URL=""

# --- Allocator-sync daemon (profiles: allocator) ---
ALLOC_SYNC_CYCLE_SEC="300"     # how often the daemon runs (seconds)
ALLOC_SYNC_BUDGET_USDC="20.0"  # hard cap — never allocates more than this total
ALLOC_SYNC_WINDOW_HOURS="24.0" # scoring lookback window
ALLOC_SYNC_ENFORCE="true"      # false = log-only dry run
ALLOC_SYNC_MIN_DELTA_USDC="0.50" # min per-agent shift to trigger env write + restart
SWARM_ENV_PATH="/Users/mymac/Desktop/poly/bot/.env"  # host path to swarm .env

# --- Swarm bot (sister multi-agent bot, shared deposit wallet) ---
SWARM_RESERVE_USDC="0"         # set >0 only when swarm is live
SWARM_AGENT_ALLOCATIONS_JSON='{"market_maker":5,"mean_reversion":5,"nothing_happens":5,"ai_decision":5,"arbitrage":0}'
							   # dashboard-only: per-agent budget map (USD) for Swarm tab summary

# --- Scalper (Strategy C — short-duration crypto Up/Down) ---
EXECUTE_SCALPER="false"        # flip to true after Stage-0 validation
SCALPER_RESERVE_USDC="14"      # hard reserve, Trader cannot touch
MAX_SCALP_TRADES_PER_HOUR="60"
SCALP_LEG_USDC="2.5"           # Stage-0/1 leg size; raise in Stage 2
SCALP_ENTRY_THRESHOLD="0.499"
SCALP_REVERSAL_DELTA="0.020"
SCALP_DEPTH_DISCOUNT="0.05"
SCALP_SECOND_BUFFER="0.01"
SCALP_SECOND_TIME_MS="200"
SCALP_DYNAMIC_BOOST="0.04"
SCALP_MAX_SUM_AVG="0.97"       # Stage-1 starts tighter than TS default 0.98
SCALP_MAX_BUYS_PER_SIDE="4"
SCALP_POLL_MS="500"            # Stage-0 starts loose; tighten if needed
SCALP_DISCOVER_EVERY_SEC="60"
SCALPER_HEARTBEAT_PATH="/app/data/scalper_heartbeat"

# --- MarketBrain (shared approval/veto layer; does not place orders) ---
MARKET_BRAIN_ENABLED="true"
MARKET_BRAIN_STRICT_UNKNOWN="false"
MARKET_BRAIN_SCALPER_MIN_SECONDS_TO_EXPIRY="90"
MARKET_BRAIN_SCALPER_MAX_ENTRY_PRICE="0.55"
MARKET_BRAIN_SCALPER_MAX_PAIR_ASK_SUM="1.04"
MARKET_BRAIN_SCALPER_MIN_EDGE_SCORE="0.35"
MARKET_BRAIN_EXIT_TAKE_PROFIT_PCT="0.25"  # hard cap: do not hold past +25%
MARKET_BRAIN_EXIT_TRAILING_STOP_PCT="0.02"
MARKET_BRAIN_EXIT_SOFT_STOP_LOSS_PCT="0.03" # force brain review, not blind sell
MARKET_BRAIN_EXIT_STOP_LOSS_PCT="0.06"      # hard stop guardrail
MARKET_BRAIN_EXIT_MAX_HOLD_SECONDS="21600"  # hard safety ceiling, not a target hold time
META_BRAIN_MIN_EDGE_PCT="0.02"
META_BRAIN_MIN_RAW_EV="0.04"
META_BRAIN_EXECUTION_QUALITY_ENABLED="true"
META_BRAIN_EXECUTION_QUALITY_FAIL_CLOSED="false"
META_BRAIN_EXECUTION_QUALITY_USDC="3.0"
EXECUTION_QUALITY_REQUIRE_FRESH="true"
EXECUTION_QUALITY_MAX_AGE_SEC="10"
EXECUTION_QUALITY_MAX_SPREAD_PCT="0.05"
EXECUTION_QUALITY_MIN_BID_DEPTH_USDC="20"
EXECUTION_QUALITY_MAX_AVG_SLIPPAGE_PCT="0.025"
EXECUTION_QUALITY_MIN_SCORE="0.65"
EXECUTION_QUALITY_FEE_BUFFER_PCT="0.01"
EXECUTION_QUALITY_MIN_NET_EV="0.02"
ORDERBOOK_MONITOR_POLL_SEC="1"
ORDERBOOK_MONITOR_TOKEN_LIMIT="80"
ORDERBOOK_MONITOR_PRUNE_MINUTES="180"
ORDERBOOK_MONITOR_STALE_MARKET_GRACE_SEC="300"
PREFLIGHT_MAX_DISK_USED_PCT="85"
PREFLIGHT_REQUIRE_DB_BACKUP="true"
PREFLIGHT_MAX_BACKUP_AGE_HOURS="30"
META_BRAIN_WINRATE_PRIOR="0.50"
META_BRAIN_ANCHOR_THRESHOLD="0.70"
META_BRAIN_MIN_WEIGHTED_SCORE_ANCHOR="0.40"
META_BRAIN_WEIGHT_NEWS="0.10"
EXPERT_RELIABILITY_HOURS="720"
EXPERT_SOLO_MIN_PROB="0.65"
EXPERT_SOLO_MIN_WINRATE="0.65"
EXPERT_SOLO_MIN_WILSON="0.58"
EXPERT_SOLO_MIN_SAMPLES="30"
EXPERT_SOLO_MAX_AGE_SEC="3600"
EXPERT_EXTERNAL_SOLO_SOURCE_TYPES="cross_market,equity_fv,alpaca_market_data,openbb_market_data,crypto_exchange_tape"
EXPERT_EXTERNAL_SOLO_MIN_CONFIDENCE="0.60"
EXPERT_EXTERNAL_SOLO_MAX_AGE_SEC="300"
EXPERT_EXTERNAL_SOLO_MIN_EQUITY_EDGE="0.08"
EXPERT_EXTERNAL_SOLO_MAX_SPREAD_PCT="0.003"
EXPERT_WALLET_EXTERNAL_MIN_WINRATE="0.70"
EXPERT_WALLET_EXTERNAL_MIN_TRADES="50"
EXPERT_WALLET_EXTERNAL_MIN_PROFIT_USDC="100"
EXPERT_CONFLICT_MIN_PROB="0.62"
EXPERT_CONFLICT_MIN_WINRATE="0.58"
EXPERT_CONFLICT_MIN_SAMPLES="15"
MARKET_BRAIN_TIMEOUT_FLAT_GRACE_PCT="0.01"   # ±1% = "flat" — hold instead of timeout-sell
MARKET_BRAIN_TIMEOUT_GRACE_SECONDS="3600"    # 1h extra hold if flat at timeout
MARKET_BRAIN_SMART_EXIT_ENABLED="true"
MARKET_BRAIN_SMART_EXIT_MIN_PROFIT_PCT="0.015" # profit can be taken if brain/EV fades
MARKET_BRAIN_PREFERRED_TAKE_PROFIT_PCT="0.04"  # preferred exit zone starts here
MARKET_BRAIN_SMART_EXIT_MOMENTUM_WINDOW="60s"
MARKET_BRAIN_SMART_EXIT_MIN_MOMENTUM_PCT="0.001"
