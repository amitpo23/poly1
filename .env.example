# --- Required ---
POLYGON_WALLET_PRIVATE_KEY=""
OPENAI_API_KEY=""

# Polymarket proxy address (the wallet shown on polymarket.com/settings).
# REQUIRED for accounts created via Google/email login (Privy/Magic embedded
# wallet) — the EOA derived from the private key signs orders, but the proxy
# is the order funder and balance holder. Leave blank for classic EOA-only
# (MetaMask) wallets.
POLYMARKET_FUNDER=""

# Deposit-wallet mode (current Polymarket API path for new API users).
# Once deployed/funded, set this and leave POLYMARKET_SIGNATURE_TYPE=3.
POLYMARKET_DEPOSIT_WALLET=""
POLYMARKET_SIGNATURE_TYPE=""

# Required only for automated deposit-wallet deployment/approval/migration via
# scripts/python/setup_deposit_wallet.py.
BUILDER_API_KEY=""
BUILDER_SECRET=""
BUILDER_PASS_PHRASE=""
POLYMARKET_RELAYER_URL="https://relayer-v2.polymarket.com/"

# Optional: persist CLOB L2 credentials after deriving them once. If these are
# blank, the bot derives them from POLYGON_WALLET_PRIVATE_KEY at startup.
POLYMARKET_CLOB_API_KEY=""
POLYMARKET_CLOB_API_SECRET=""
POLYMARKET_CLOB_API_PASSPHRASE=""

# Optional: order attribution for builder integrations. Leave blank unless you
# created a builder code in Polymarket settings.
POLYMARKET_BUILDER_CODE=""
POLYMARKET_BUILDER_ADDRESS=""

# --- Optional but used by features ---
TAVILY_API_KEY=""
NEWSAPI_API_KEY=""

# --- Model ---
# Default: gpt-3.5-turbo-16k. Recommended for production: gpt-4o-mini (cheap) or gpt-4o (quality).
OPENAI_MODEL="gpt-4o-mini"

# --- Trader runtime ---
# Set EXECUTE=true to leave dry-run and place real orders. Default false.
EXECUTE="false"
# Shadow-only experiments may continue producing paper decisions even when the
# live risk gate blocks entries. Ignored when EXECUTE=true.
SHADOW_IGNORE_RISK_GATE="false"
CYCLE_SECONDS="1800"          # 30 minutes between sweeps
CYCLE_JITTER_SECONDS="30"
TOP_N="3"
MAX_TRADES_PER_CYCLE="2"
MAX_POSITION_FRACTION="0.05"
MIN_CONFIDENCE="0.60"

# --- Risk gates ---
# Set this to your wallet's actual starting balance so drawdown is measured correctly.
STARTING_BALANCE_USDC="50.0"
MAX_DAILY_LOSS_PCT="0.10"     # halt trading if drawdown exceeds 10%
MAX_TRADES_PER_HOUR="4"
MIN_USDC_FLOOR="10.0"
MAX_DAILY_TOKEN_USD="5.0"
KILL_SWITCH_FILE="/app/data/HALT"

# Slippage guard: reject FOK market buys where the effective price exceeds the
# model price by more than this fraction. Default 0.03 (3%).
POLYMARKET_MAX_SLIPPAGE="0.03"

# Minimum USDC per live order. Orders smaller than this are skipped. Default 1.0.
POLYMARKET_MIN_ORDER_USDC="1.0"

# Polygon RPC endpoint. Override with a paid Alchemy/Infura/QuickNode URL for
# production stability. Default uses a public free node.
POLYGON_RPC="https://polygon.drpc.org"

# --- Persistence ---
TRADE_LOG_DB="/app/data/trade_log.db"
LLM_USAGE_FILE="/app/data/llm_usage.jsonl"
LOG_DIR="/app/data/logs"
LOG_LEVEL="INFO"
HEARTBEAT_PATH="/app/data/heartbeat"

# --- Notifications ---
TG_BOT_TOKEN=""
TG_CHAT_ID=""
HEALTHCHECK_URL=""

# --- Allocator-sync daemon (profiles: allocator) ---
ALLOC_SYNC_CYCLE_SEC="300"     # how often the daemon runs (seconds)
ALLOC_SYNC_BUDGET_USDC="20.0"  # hard cap — never allocates more than this total
ALLOC_SYNC_WINDOW_HOURS="24.0" # scoring lookback window
ALLOC_SYNC_ENFORCE="true"      # false = log-only dry run
ALLOC_SYNC_MIN_DELTA_USDC="0.50" # min per-agent shift to trigger env write + restart
SWARM_ENV_PATH="/Users/mymac/Desktop/poly/bot/.env"  # host path to swarm .env

# --- Swarm bot (sister multi-agent bot, shared deposit wallet) ---
SWARM_RESERVE_USDC="0"         # set >0 only when swarm is live
SWARM_AGENT_ALLOCATIONS_JSON='{"market_maker":5,"mean_reversion":5,"nothing_happens":5,"ai_decision":5,"arbitrage":0}'
							   # dashboard-only: per-agent budget map (USD) for Swarm tab summary

# --- Scalper (Strategy C — short-duration crypto Up/Down) ---
EXECUTE_SCALPER="false"        # flip to true after Stage-0 validation
SCALPER_RESERVE_USDC="14"      # hard reserve, Trader cannot touch
MAX_SCALP_TRADES_PER_HOUR="60"
SCALP_LEG_USDC="2.5"           # Stage-0/1 leg size; raise in Stage 2
SCALP_ENTRY_THRESHOLD="0.499"
SCALP_REVERSAL_DELTA="0.020"
SCALP_DEPTH_DISCOUNT="0.05"
SCALP_SECOND_BUFFER="0.01"
SCALP_SECOND_TIME_MS="200"
SCALP_DYNAMIC_BOOST="0.04"
SCALP_MAX_SUM_AVG="0.97"       # Stage-1 starts tighter than TS default 0.98
SCALP_MAX_BUYS_PER_SIDE="4"
SCALP_POLL_MS="500"            # Stage-0 starts loose; tighten if needed
SCALP_DISCOVER_EVERY_SEC="60"
SCALPER_HEARTBEAT_PATH="/app/data/scalper_heartbeat"

# --- MarketBrain (shared approval/veto layer; does not place orders) ---
MARKET_BRAIN_ENABLED="true"
MARKET_BRAIN_STRICT_UNKNOWN="false"
MARKET_BRAIN_SCALPER_MIN_SECONDS_TO_EXPIRY="90"
MARKET_BRAIN_SCALPER_MAX_ENTRY_PRICE="0.55"
MARKET_BRAIN_SCALPER_MAX_PAIR_ASK_SUM="1.04"
MARKET_BRAIN_SCALPER_MIN_EDGE_SCORE="0.35"
MARKET_BRAIN_EXIT_TAKE_PROFIT_PCT="0.05"
MARKET_BRAIN_EXIT_TRAILING_STOP_PCT="0.02"
MARKET_BRAIN_EXIT_STOP_LOSS_PCT="0.07"
MARKET_BRAIN_EXIT_MAX_HOLD_SECONDS="1800"
MARKET_BRAIN_SMART_EXIT_ENABLED="true"
MARKET_BRAIN_SMART_EXIT_MIN_PROFIT_PCT="0.05"
MARKET_BRAIN_SMART_EXIT_MOMENTUM_WINDOW="60s"
MARKET_BRAIN_SMART_EXIT_MIN_MOMENTUM_PCT="0.001"
MARKET_BRAIN_SMART_EXIT_PEAK_DRAWDOWN_HOLD_PCT="0.006"
MARKET_BRAIN_SMART_EXIT_MIN_SECONDS_TO_EXPIRY="75"
MARKET_BRAIN_CRYPTO_MIN_SAMPLES="2"

# --- Position maintenance / live exit executor ---
EXECUTE_MAINTAIN="false"
EXECUTE_BTC_DAILY="false"
BTC_DAILY_RESERVE_USDC="6.0"
BTC_DAILY_POSITION_SIZE_USDC="3.0"
BTC_DAILY_TRIGGER_PCT="0.002"
BTC_DAILY_MAX_SLIPPAGE_SKIPS="3"   # give up on a market after N consecutive slippage failures

# --- Near-Resolution Agent (Strategy E) ---
EXECUTE_NEAR_RESOLUTION="false"
NEAR_RESOLUTION_RESERVE_USDC="15.0"         # USDC reserved for this agent
NEAR_RESOLUTION_POSITION_SIZE_USDC="2.5"    # size per trade
NEAR_RESOLUTION_MIN_HOURS="0.5"             # min hours to market close
NEAR_RESOLUTION_MAX_HOURS="336.0"           # max hours to market close (336h=2w; raised 2026-05-12 — active Polymarket markets rarely close within 36h)
NEAR_RESOLUTION_MAX_ENTRY_PRICE="0.15"      # max price for cheap side
NEAR_RESOLUTION_MIN_LIQUIDITY="500"         # min $USDC book depth (lowered 2026-05-12 from 3000; $3k filtered all markets)
NEAR_RESOLUTION_MIN_CONFIDENCE="0.65"       # Tavily confidence threshold 0-1
NEAR_RESOLUTION_MAX_OPEN="3"                # max concurrent NR positions
NEAR_RESOLUTION_POLL_SEC="60"               # loop cadence seconds

# --- News-Shock Agent (Strategy F) ---
EXECUTE_NEWS_SHOCK="false"
NEWS_SHOCK_RESERVE_USDC="15.0"              # USDC reserved for this agent
NEWS_SHOCK_POSITION_SIZE_USDC="2.5"         # size per trade
NEWS_SHOCK_MIN_SCORE="0.70"                 # min materiality from news_signal
NEWS_SHOCK_MAX_AGE_HOURS="2.0"             # max signal age in hours
NEWS_SHOCK_MIN_EV="0.04"                    # min expected value (0-1)
NEWS_SHOCK_MAX_ENTRY_PRICE="0.60"           # max entry price for entered token
NEWS_SHOCK_MIN_LIQUIDITY="5000"             # min $USDC volume on market
NEWS_SHOCK_MAX_OPEN="3"                     # max concurrent NS positions
NEWS_SHOCK_POLL_SEC="30"                    # loop cadence seconds

# --- Wallet-Watcher (smart-wallet signal producer) ---
WALLET_WATCH_ADDRESSES=""                   # comma-separated proxy wallet hex addresses
WALLET_SCOUT_ENABLE="false"                 # true = auto-discover top traders from leaderboard
WALLET_SCOUT_LIMIT="20"                     # max wallets from leaderboard
WALLET_SCOUT_MIN_PROFIT_USDC="200"          # min 30d profit for scout candidate
WALLET_SCOUT_MIN_TRADES="15"               # min 30d trade count for scout candidate
WALLET_WATCHER_POLL_SEC="120"               # loop cadence seconds
WALLET_WATCHER_MAX_AGE_HOURS="4.0"          # max trade age to generate signals

# --- Wallet-Follow Agent (Strategy G) ---
EXECUTE_WALLET_FOLLOW="false"
WALLET_FOLLOW_RESERVE_USDC="15.0"           # USDC reserved for this agent
WALLET_FOLLOW_POSITION_SIZE_USDC="2.5"      # size per trade
WALLET_FOLLOW_MIN_CONFIDENCE="0.50"         # min confidence (from wallet profit)
WALLET_FOLLOW_PROFIT_SCALE="1000.0"         # wallet profit $ for full confidence
WALLET_FOLLOW_MIN_EV="0.03"                 # min expected value (0-1)
WALLET_FOLLOW_MAX_ENTRY_PRICE="0.70"        # max entry price for copied token
WALLET_FOLLOW_MIN_LIQUIDITY="3000"          # min $USDC volume on market
WALLET_FOLLOW_MAX_AGE_HOURS="4.0"           # max signal age hours to act
WALLET_FOLLOW_MAX_OPEN="3"                  # max concurrent WF positions
WALLET_FOLLOW_POLL_SEC="60"                 # loop cadence seconds

MAINTAIN_TAKE_PROFIT_PCT="0.05"
MAINTAIN_TRAILING_STOP_PCT="0.02"
MAINTAIN_STOP_LOSS_PCT="0.03"   # tightened 2026-05-12: 7% → 3% to cut per-trade loss from $0.21 → $0.09
MAINTAIN_MAX_HOLD_HOURS="24"
MAINTAIN_POLL_SEC="15"
MAINTAIN_SELL_SLIPPAGE="0.02"
MAINTAIN_MIN_EXIT_NOTIONAL_USDC="1.0"
MAINTAIN_HEARTBEAT_PATH="/app/data/position_manager_heartbeat"

# --- Trading supervisor (exit-path guard) ---
TRADING_SUPERVISOR_POLL_SEC="60"
TRADING_SUPERVISOR_ENFORCE_HALT="true"
TRADING_SUPERVISOR_EVAL_GRACE_SEC="180"
TRADING_SUPERVISOR_STALE_HEARTBEAT_SEC="180"
TRADING_SUPERVISOR_MIN_POSITION_AGE_SEC="45"
TRADING_SUPERVISOR_CLOSE_FAILED_WINDOW_MIN="15"
TRADING_SUPERVISOR_CLOSE_FAILED_THRESHOLD="5"
TRADING_SUPERVISOR_SETTLEMENT_MAX_AGE_MIN="15"
TRADING_SUPERVISOR_HEARTBEAT_PATH="/app/data/trading_supervisor_heartbeat"
TRADING_SUPERVISOR_STATE_PATH="/app/data/trading_supervisor_status.json"
TRADING_SUPERVISOR_POSITION_MANAGER_HEARTBEAT="/app/data/position_manager_heartbeat"

# --- Settlement reconciler (wallet/journal/market state) ---
SETTLEMENT_RECONCILER_ENABLED="true"
SETTLEMENT_RECONCILER_POLL_SEC="300"
SETTLEMENT_RECONCILER_HEARTBEAT_PATH="/app/data/settlement_reconciler_heartbeat"
SETTLEMENT_MIN_RECOVERABLE_USDC="1.0"
SETTLEMENT_GAS_ESTIMATE_USDC="0.05"
SETTLEMENT_REDEEMABLE_SHARES_FLOOR="0.5"
SETTLEMENT_ON_CHAIN_DUST_FLOOR="0.5"
SETTLEMENT_EXIT_EVIDENCE_GRACE_SEC="240"
SETTLEMENT_REQUIRE_EXIT_EVIDENCE="true"

# --- Grafana (monitoring dashboard) ---
GF_ADMIN_PASSWORD="admin"      # שנה לפני חשיפה לרשת חיצונית

# --- Capital allocation per agent ($5/trade) ---
# Trader: MAX_POSITION_FRACTION × wallet_balance = trade size
#   e.g. wallet=$100, fraction=0.05 → $5/trade
MAX_POSITION_FRACTION="0.05"
# Scalper: SCALP_LEG_USDC = $5 per leg (set above in Scalper section)
# SCALP_LEG_USDC="5.0"        # uncomment to override Stage-1 default of 2.5
