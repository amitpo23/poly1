MARKET_BRAIN_SMART_EXIT_MIN_SECONDS_TO_EXPIRY="75"
MARKET_BRAIN_CRYPTO_MIN_SAMPLES="2"

# --- Position maintenance / live exit executor ---
EXECUTE_MAINTAIN="false"
EXECUTE_BTC_DAILY="false"
BTC_DAILY_RESERVE_USDC="6.0"
BTC_DAILY_POSITION_SIZE_USDC="3.0"
BTC_DAILY_TRIGGER_PCT="0.002"
BTC_DAILY_MAX_SLIPPAGE_SKIPS="3"   # give up on a market after N consecutive slippage failures

# --- BTC 5-Min Agent (multi-signal consensus on 5-min up/down) ---
EXECUTE_BTC_5MIN="false"
BTC_5MIN_RESERVE_USDC="3.0"
BTC_5MIN_POSITION_SIZE_USDC="1.5"
BTC_5MIN_ENTRY_WINDOW_START="60"       # seconds after period open
BTC_5MIN_ENTRY_WINDOW_END="180"        # latest entry point (seconds)
BTC_5MIN_MOMENTUM_PCT="0.0015"        # 0.15% min BTC move for momentum signal
BTC_5MIN_MIN_CONFIDENCE="0.60"        # normal BTC 5m entries need stronger evidence; 0.52 is solo-expert only
BTC_5MIN_MIN_CONSENSUS="2"             # min agreeing signals out of 3
BTC_5MIN_NEWS_VETO="true"             # skip entry on high-impact BTC news
BTC_5MIN_POLL_SEC="3"                  # loop cadence
BTC_5MIN_COOLDOWN_SEC="300"            # = one 5-min window
BTC_5MIN_MAX_PER_HOUR="6"             # hard trade cap
BTC_5MIN_STRADDLE_ENABLED="false"      # disabled until spread/backtest data proves positive EV

# --- Near-Resolution Agent (Strategy E) ---
EXECUTE_NEAR_RESOLUTION="false"
NEAR_RESOLUTION_RESERVE_USDC="15.0"         # USDC reserved for this agent
NEAR_RESOLUTION_POSITION_SIZE_USDC="2.5"    # size per trade
NEAR_RESOLUTION_MIN_HOURS="0.5"             # min hours to market close
NEAR_RESOLUTION_MAX_HOURS="336.0"           # max hours to market close (336h=2w; raised 2026-05-12 — active Polymarket markets rarely close within 36h)
NEAR_RESOLUTION_MAX_ENTRY_PRICE="0.15"      # max price for cheap side
NEAR_RESOLUTION_MIN_LIQUIDITY="500"         # min $USDC book depth (lowered 2026-05-12 from 3000; $3k filtered all markets)
NEAR_RESOLUTION_MIN_CONFIDENCE="0.65"       # Tavily confidence threshold 0-1
NEAR_RESOLUTION_MAX_OPEN="3"                # max concurrent NR positions
NEAR_RESOLUTION_POLL_SEC="60"               # loop cadence seconds

# --- News-Shock Agent (Strategy F) ---
EXECUTE_NEWS_SHOCK="false"
NEWS_SHOCK_RESERVE_USDC="15.0"              # USDC reserved for this agent
NEWS_SHOCK_POSITION_SIZE_USDC="2.5"         # size per trade
NEWS_SHOCK_MIN_SCORE="0.70"                 # min materiality from news_signal
NEWS_SHOCK_MAX_AGE_HOURS="2.0"             # max signal age in hours
NEWS_SHOCK_MIN_EV="0.04"                    # min expected value (0-1)
NEWS_SHOCK_MAX_ENTRY_PRICE="0.60"           # max entry price for entered token
NEWS_SHOCK_MIN_LIQUIDITY="5000"             # min $USDC volume on market
NEWS_SHOCK_MAX_OPEN="3"                     # max concurrent NS positions
NEWS_SHOCK_POLL_SEC="30"                    # loop cadence seconds

# --- Crypto 5m Market-Maker Shadow (mispricing/spread probe) ---
# Shadow-only evidence collector for BTC/ETH/SOL/XRP/DOGE/BNB 5m Up/Down
# markets. It does not place orders. It measures whether tiny maker quotes
# would have positive markout after spread, and now uses crypto exchange tape
# to avoid quoting against strong directional pressure.
CRYPTO_5M_MM_SHADOW_POLL_SEC="2"
CRYPTO_5M_MM_SHADOW_UNIVERSE_LIMIT="80"
CRYPTO_5M_MM_SHADOW_QUOTE_SIZE_USDC="1.0"
